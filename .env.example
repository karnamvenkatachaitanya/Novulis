# ==============================================================================
# Compliance Automation System - Environment Variables Example
# Copy this file to '.env' and fill in your credentials.
# ==============================================================================

# --- Live Web Portal State Capture (scraper.py) ---
APP_BASE_URL=https://white-cliff-0bca3ed00.1.azurestaticapps.net
APP_LOGIN_PATH=/login
APP_LOGIN_EMAIL=admin@gmail.com
APP_LOGIN_PASSWORD=your_portal_password_here
DASHBOARD_READY_SELECTOR=.dashboard-container

# --- Supabase Vector DB Credentials ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- SMTP Alerting Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
ALERT_FROM=your_email@gmail.com
ALERT_TO=stakeholder@example.com

# --- LLM Compliance Model (Hugging Face Serverless Inference API) ---
COMPLIANCE_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_TOKEN=your_hugging_face_read_token_here

# --- Auto Healer Verification Command ---
AUTO_HEALER_TEST_COMMAND=python -m unittest tests/test_compliance.py
